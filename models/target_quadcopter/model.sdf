<?xml version="1.0" ?>
<sdf version="1.8">
  <model name="target_quadcopter">
    <link name="base_link">
      <inertial>
        <mass>1.2</mass>
        <inertia>
          <ixx>0.011</ixx><iyy>0.011</iyy><izz>0.021</izz>
          <ixy>0</ixy><ixz>0</ixz><iyz>0</iyz>
        </inertia>
      </inertial>
      <visual name="body_visual">
        <geometry><box><size>0.12 0.12 0.06</size></box></geometry>
        <material><ambient>0.1 0.1 0.5 1</ambient><diffuse>0.1 0.1 0.5 1</diffuse></material>
      </visual>
      <collision name="body_collision">
        <geometry><box><size>0.12 0.12 0.06</size></box></geometry>
      </collision>
      <visual name="arm_ne"><pose>0.106 0.106 0 0 0 0.7854</pose>
