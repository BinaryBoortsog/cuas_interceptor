      <visual name="prop_ne"><pose>0.18 0.18 0.02 0 0 0</pose>
        <geometry><cylinder><radius>0.0635</radius><length>0.005</length></cylinder></geometry>
        <material><ambient>0.3 0.3 0.3 0.7</ambient></material></visual>
      <collision name="prop_ne_col"><pose>0.18 0.18 0.02 0 0 0</pose>
        <geometry><cylinder><radius>0.0635</radius><length>0.005</length></cylinder></geometry></collision>
      <visual name="prop_nw"><pose>-0.18 0.18 0.02 0 0 0</pose>
